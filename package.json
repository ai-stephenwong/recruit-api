{
  "name": "recruit-api",
  "version": "1.0.0",
  "description": "Recruit.com.hk - Hong Kong Job Recruitment Platform API",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply recruit-db",
    "db:migrate:local": "wrangler d1 migrations apply recruit-db --local",
    "db:create": "wrangler d1 create recruit-db",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.1.0",
    "jose": "^5.2.0",
    "openai": "^6.27.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.28.0"
  }
}
